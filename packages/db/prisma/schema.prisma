// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}



model User {
  userid     String  @id @default(uuid())
  username   String  @unique
  password   String
  orders     Order[]
  makerFills Fill[]  @relation("MakerFills")
  takerFills Fill[]  @relation("TakerFills")
}

//market

model Order {
  orderid       String      @id @default(uuid())
  userId        String // foreign key connecting order to user
  market        String
  side          OrderSide
  type          OrderType
  qty           String
  filledQty     String
  price         String
  initialMargin String
  slippage      String
  status        OrderStatus
  createdAt     DateTime    @default(now())
  updateAt      DateTime    @updatedAt
  user          User        @relation(fields: [userId], references: [userid])

  buyFills  Fill[] @relation("buyOrderFills")
  sellFills Fill[] @relation("sellOrderFills")
}

enum OrderStatus {
  open
  filled
  partiall_filled
  closed
}

enum OrderSide {
  buy
  sell
}

enum OrderType {
  limit
  market
}

model Fill {
  fillId      String   @id @default(uuid())
  market      String
  makerUserId String
  takerUserId String
  buyOrderId  String
  sellOrderId String
  price       String
  qty         String
  createAt    DateTime @default(now())
  maker       User     @relation("MakerFills", fields: [makerUserId], references: [userid])
  taker       User     @relation("TakerFills", fields: [takerUserId], references: [userid])
  buyOrder    Order    @relation("buyOrderFills", fields: [buyOrderId], references: [orderid])
  sellOrder   Order    @relation("sellOrderFills", fields: [sellOrderId], references: [orderid])
}

